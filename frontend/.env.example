# Copy to frontend/.env.local for the Next.js demo API route.
# Keep real keys and private endpoints out of git.

# Generic/base model served through an OpenAI-compatible chat API.
OPENAI_COMPATIBLE_BASE_URL=http://localhost:8000/v1
OPENAI_COMPATIBLE_API_KEY=local
OPENAI_COMPATIBLE_MODEL=lfm2-350m-base
OPENAI_COMPATIBLE_TIMEOUT_SECONDS=30
OPENAI_COMPATIBLE_MAX_RETRIES=1
OPENAI_COMPATIBLE_MAX_TOKENS=512
# Supported by the frontend route: off, json_object, json_schema, structured_outputs, guided_json, responses_parse
OPENAI_COMPATIBLE_RESPONSE_FORMAT=structured_outputs
# Optional sampling/backend overrides.
# OPENAI_COMPATIBLE_TEMPERATURE=0
# OPENAI_COMPATIBLE_TOP_P=0.9
# OPENAI_COMPATIBLE_EXTRA_BODY={"min_p":0.15,"repetition_penalty":1.05}

# Fine-tuned model served through an OpenAI-compatible chat API.
OPENAI_FINETUNE_BASE_URL=http://localhost:8000/v1
OPENAI_FINETUNE_API_KEY=local
OPENAI_FINETUNE_MODEL=lfm2-350m-security-triage-lora
OPENAI_FINETUNE_TIMEOUT_SECONDS=30
OPENAI_FINETUNE_MAX_RETRIES=1
OPENAI_FINETUNE_MAX_TOKENS=512
OPENAI_FINETUNE_RESPONSE_FORMAT=structured_outputs
# OPENAI_FINETUNE_TEMPERATURE=0
# OPENAI_FINETUNE_TOP_P=0.9
# OPENAI_FINETUNE_EXTRA_BODY={"min_p":0.15,"repetition_penalty":1.05}
