# Generic/base model served through an OpenAI-compatible chat API.
OPENAI_COMPATIBLE_BASE_URL=http://localhost:8000/v1
OPENAI_COMPATIBLE_API_KEY=changeme
OPENAI_COMPATIBLE_MODEL=lfm2-350m-base
OPENAI_COMPATIBLE_TIMEOUT_SECONDS=30
OPENAI_COMPATIBLE_MAX_RETRIES=1
OPENAI_COMPATIBLE_MAX_TOKENS=512
# Supported values: off, json_object, json_schema, structured_outputs, guided_json, responses_parse
OPENAI_COMPATIBLE_RESPONSE_FORMAT=responses_parse
OPENAI_COMPATIBLE_SCHEMA_PATH=data/schemas/triage-output.schema.json
# Optional. If omitted, adapter also looks for local config-adapter.yml.
# OPENAI_COMPATIBLE_CONFIG_PATH=config-adapter.yml

# Fine-tuned model served through an OpenAI-compatible chat API.
OPENAI_FINETUNE_BASE_URL=http://localhost:8000/v1
OPENAI_FINETUNE_API_KEY=changeme
OPENAI_FINETUNE_MODEL=lfm2-350m-security-triage-lora
OPENAI_FINETUNE_TIMEOUT_SECONDS=30
OPENAI_FINETUNE_MAX_RETRIES=1
OPENAI_FINETUNE_MAX_TOKENS=512
# Supported values: off, json_object, json_schema, structured_outputs, guided_json, responses_parse
OPENAI_FINETUNE_RESPONSE_FORMAT=responses_parse
OPENAI_FINETUNE_SCHEMA_PATH=data/schemas/triage-output.schema.json
# OPENAI_FINETUNE_CONFIG_PATH=config-adapter.yml

# Optional shared adapter config path. Adapter-specific paths above win over this.
# OPENAI_ADAPTER_CONFIG_PATH=config-adapter.yml
